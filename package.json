{
  "name": "pdi-board",
  "version": "1.0.0",
  "description": "PDI Board — Plano de Desenvolvimento Individual estilo jogo de tabuleiro",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "npx nodemon server/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/index.js"
    ],
    "coverageReporters": [
      "lcov",
      "text",
      "clover"
    ],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^4.13.23",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
