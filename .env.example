# Variáveis de ambiente — copie este arquivo para .env e preencha os valores

# ── Banco de dados (Supabase → Project Settings → Database → URI) ──────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Clerk (Dashboard → API Keys) ──────────────────────────────────────────────
# Publishable key: usada no frontend (pode ser exposta)
CLERK_PUBLISHABLE_KEY=pk_test_...
# Secret key: usada no backend (NUNCA expor no frontend ou commitar)
CLERK_SECRET_KEY=sk_test_...

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
